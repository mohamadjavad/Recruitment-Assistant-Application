# ══════════════════════════════════════════════════════════════
# Recruitment Assistant — Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# The web UI setup wizard can also generate this file.
# ══════════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────────
# Required. The primary LLM API key (OpenAI-compatible).
OPENAI_API_KEY=your_openai_api_key_here

# Required for GLM/Ollama/custom endpoints that use a different key variable.
# If your provider uses a separate key, set both.
GLM_API_KEY=your_glm_api_key_here

# Custom LLM base URL (set for OpenAI-compatible providers like GLM, Ollama, LM Studio).
# Default: https://api.iamhc.cn (GLM-5.2)
# Examples:
#   Ollama: http://localhost:11434/v1
#   OpenAI: https://api.openai.com/v1
GLM_BASE_URL=https://api.iamhc.cn

# ── Serper.dev ─────────────────────────────────────────────────
# Required for web search functionality (SerperDevTool).
SERPER_API_KEY=your_serper_api_key_here

# ── Next.js ────────────────────────────────────────────────────
# The public URL of the Next.js app (used for CORS, callbacks).
# In development: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── LLM Model Selection ────────────────────────────────────────
# The model identifier used for agent reasoning.
# Examples: glm-5.2, gpt-4, gpt-4o, ollama/llama3
LLM_MODEL=glm-5.2

# Optional: Alternative env var for base URL (read by CrewAI internals).
# OPENAI_BASE_URL=…

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Output ─────────────────────────────────────────────────────
OUTPUT_DIR=./reports
