# Recruitment Assistant Environment Variables
# Copy this file to .env and fill in your values

# LLM API Key (required — OpenAI-compatible provider)
OPENAI_API_KEY=your_api_key_here

# Serper.dev API Key (required for web search functionality)
SERPER_API_KEY=your_serper_api_key_here

# LLM Configuration
# Model identifier for agent reasoning
LLM_MODEL=glm-5.2

# Custom LLM endpoint (set for OpenAI-compatible providers like GLM, Ollama, LM Studio)
# Default: https://api.iamhc.cn (GLM-5.2)
# Example for Ollama: http://localhost:11434/v1
LLM_BASE_URL=https://api.iamhc.cn

# Optional: LinkedIn session cookie (demo only, not for production use)
# LI_AT=your_linkedin_session_cookie_here

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Output directory for reports
OUTPUT_DIR=./reports
